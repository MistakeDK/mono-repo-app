{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    // "paths": {
    //   "@mono/ui-components": ["libs/ui-components/src/index.ts"],
    //   "@mono/ui-components/*": ["libs/ui-components/src/*"],
    //   "@mono/utils": ["libs/utils/src/index.ts"],
    //   "@/*": ["./*"]
    // },
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@mono/source"]
  }
}
